# ───────── LBAMonitor .env.example v4.3 ─────────
# Copia este archivo a .env y reemplaza los valores por secrets reales.
# NUNCA commitear el archivo .env real.

# ─── Entorno ───
# "production" exige secrets obligatorios; "development" usa defaults seguros
LBAMONITOR_ENV=production

# ─── JWT Auth (OBLIGATORIO en producción) ───
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
LBAMONITOR_SECURITY__JWT_SECRET=tu-jwt-secret-aleatorio-de-64-chars-aqui
LBAMONITOR_SECURITY__JWT_ALGORITHM=HS256
LBAMONITOR_SECURITY__JWT_EXPIRATION_MINUTES=60
LBAMONITOR_SECURITY__REFRESH_EXPIRATION_DAYS=7
LBAMONITOR_SECURITY__REQUIRE_AUTH=true

# ─── Licencias (OBLIGATORIO en producción) ───
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
LBAMONITOR_LICENSE__SIGNING_SECRET=tu-license-secret-aleatorio-de-64-chars-aqui
# Alternativa: usar RSA-2048 (más seguro, no requiere compartir secret)
# LBAMONITOR_LICENSE__PUBLIC_KEY_PEM=<PEM de clave pública RSA>
# LBAMONITOR_LICENSE__PRIVATE_KEY_PEM=<PEM de clave privada RSA - solo en tools/license_generator>

# ─── Plugins (OBLIGATORIO si se cargan plugins) ───
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
LBAMONITOR_PLUGINS_SIGNING_KEY=tu-plugins-signing-key-aqui
# En desarrollo: permitir plugins sin firma
# LBAMONITOR_PLUGINS_ALLOW_UNSIGNED=1

# ─── Base de datos ───
# SQLite (kioscos individuales)
LBAMONITOR_DATABASE__ENGINE=sqlite
LBAMONITOR_DATABASE__PATH=C:/ProgramData/LBAMonitor/data/lbamonitor.db
# PostgreSQL (multi-sucursal, centralizado)
# LBAMONITOR_DATABASE__ENGINE=postgresql
# LBAMONITOR_DATABASE__HOST=localhost
# LBAMONITOR_DATABASE__PORT=5432
# LBAMONITOR_DATABASE__USER=lbamonitor
# LBAMONITOR_DATABASE__PASSWORD=tu-password-db
# LBAMONITOR_DATABASE__PATH=lbamonitor  # nombre de la BD

# ─── Servidor ───
LBAMONITOR_SERVER__HOST=127.0.0.1
LBAMONITOR_SERVER__PORT=8123
LBAMONITOR_SERVER__DOCS_ENABLED=false

# ─── Web Flask ───
LBAMONITOR_WEB_SECRET_KEY=tu-web-secret-aleatorio-aqui
LBAMONITOR_BACKEND_URL=http://127.0.0.1:8123

# ─── Backups ───
LBAMONITOR_BACKUP__ENABLED=true
LBAMONITOR_BACKUP__HOUR=3
LBAMONITOR_BACKUP__KEEP_DAYS=30
LBAMONITOR_BACKUP__DESTINATION=C:/ProgramData/LBAMonitor/backups
